# auto-dev-agent — root environment template.
# Copy to `.env` and fill in. `.env` is gitignored.
#
# All runtime configuration is also configurable via the Admin Panel UI;
# these vars only apply as initial defaults at process start.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
AGENT_LOG_LEVEL=info               # debug | info | warning | error
AGENT_PROJECT_DIR=.                # target project directory
AGENT_CONFIG_FILE=.agent.json      # runtime config file (gitignored)

# ---------------------------------------------------------------------------
# Auth & API
# ---------------------------------------------------------------------------
# Optional: pre-set a headless API token. If omitted, auto-generated on first start.
AGENT_API_TOKEN=

# Comma-separated list of allowed origins for CORS.
AGENT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Master key used to encrypt provider API keys at rest.
# Strongly recommended for production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_KEY_ENCRYPTION_KEY=

# Path to admin DB (stores encrypted provider keys & config).
AGENT_ADMIN_DB_PATH=.agent_admin.db

# ---------------------------------------------------------------------------
# SSO (optional — configure via admin panel for full setup)
# ---------------------------------------------------------------------------
# AGENT_SSO_PROVIDER=github         # github | oidc
# AGENT_SSO_CLIENT_ID=
# AGENT_SSO_CLIENT_SECRET=
# AGENT_SSO_REDIRECT_URI=http://localhost:3000/auth/callback

# ---------------------------------------------------------------------------
# LLM provider keys (preferred path: set in admin panel; these are fallbacks)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# OLLAMA_HOST=http://localhost:11434
