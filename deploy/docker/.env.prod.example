# Docker-specific environment overrides (optional).
# All settings are configurable via the Admin Panel UI.
# These env vars only apply as initial defaults for container startup.

# Optional: pre-set an API token for headless / CI deployments.
# If omitted, a random token is auto-generated on first start.
AGENT_API_TOKEN=

# Optional: restrict CORS origins (comma-separated).
AGENT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: encryption key for API keys at rest (recommended for production).
AGENT_KEY_ENCRYPTION_KEY=
